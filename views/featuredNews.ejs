<div class="container-fluid pt-5 mb-3">

    <div class="container">

        <div class="section-title">
            <h4 class="m-0 text-uppercase font-weight-bold">Noticias Destacadas</h4>
        </div>
        
        <div class="swiper swiper-container">

            <div class="swiper-wrapper"></div>

                <% outstandingNotices.forEach((notice) => { %>

                    <div class="swiper-slide">

                        <!-- Data carousel main-->
                        <div class="position-relative overflow-hidden" style="height: 300px;">

                            <img  class="img-fluid h-100" 
                            src="<%= notice.image_urls && notice.image_urls.length > 0 ? notice.image_urls[0] : ''%>" 
                            style="object-fit: cover;">

                            <div class="overlay">

                                <div class="mb-2">
                                    <a class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2" 
                                        href=""><%= getCategory(notice.category) %>
                                    </a>
                                    <a class="text-white" href="">
                                        <small><%= formatDateString(notice.publication_date) %></small>
                                    </a>
                                </div>

                                <a class="h6 m-0 text-white text-uppercase font-weight-semi-bold"
                                    href="/notice/<%= encryptId(notice.idNotice.toString(), encryptionKey) %>">
                                    <%= notice.title %>
                                </a>
                            
                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

            <!-- navigation buttons (optional) -->
            <div class="swiper-button-next">
                <i class="fa fa-angle-right"></i>
            </div>
            <div class="swiper-button-prev">
                <i class="fa fa-angle-left"></i>
            </div>

            <!-- pagination (optional) -->
            <div class="swiper-pagination"></div>

        </div>

    </div>

</div>