<!DOCTYPE html>
<html lang="en">

<head>
    <title></title>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>

    <link href="/img/newLogo.jpeg" rel="icon">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.0/css/all.min.css" rel="stylesheet">
    <link href="../public/css/style.css" rel="stylesheet">

</head>

<body>
    
    <div class="container-fluid d-none d-lg-block">

        <div class="row align-items-center bg-dark px-lg-4">

            <div class="col-lg-9">

                <nav class="navbar navbar-expand-sm bg-dark p-0">

                    <ul class="navbar-nav ml-n2">

                        <li class="nav-item border-right border-secondary">
                            <a class="nav-link text-body small">
                                <%= todayFormatted %>
                            </a>
                        </li>

                        <li class="nav-item border-right border-secondary">
                            <a class="nav-link text-body small">Contacto</a>
                        </li>

                    </ul>

                </nav>

            </div>

            <div class="col-lg-3 text-right d-none d-md-block">

                <nav class="navbar navbar-expand-sm bg-dark p-0">

                    <ul class="navbar-nav ml-auto mr-n2">

                        <li class="nav-item">
                            <a class="nav-link text-body" href="#"><small class="fab fa-tiktok"></small></a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-body" href="#"><small class="fab fa-facebook-f"></small></a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-body" href="#"><small class="fab fa-instagram"></small></a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-body" href="#"><small class="fab fa-youtube"></small></a>
                        </li>

                    </ul>

                </nav>

            </div>

        </div>

        <div class="row align-items-center bg-white py-3 px-lg-4">
            <div class="col-lg-4">
                <a href="/" class="navbar-brand p-0 d-none d-lg-block">
                    <h1 class="m-0 display-4 text-uppercase text-primary">Ruined<span
                            class="text-secondary font-weight-normal">News</span></h1>
                </a>
            </div>
        </div>
    </div>


    <!-- Main News Slider -->
    <%- include('mainNews') %>

    <!-- Featured News Slider -->
    <%- include('featuredNews') %>

    <!-- News With Sidebar Start -->
    <%- include('newsWithSidebar') %>

    <!-- Footer -->
    <%- include('partials/footer') %>

    <!-- Back to Top -->
    <a href="#" class="btn btn-primary btn-square back-to-top"><i class="fa fa-arrow-up"></i></a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Swiper JS -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    
    <script src="../public/js/index.js"></script>
</body>

</html>