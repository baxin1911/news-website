<div class="container-fluid">

    <div class="container">

        <div class="row">

            <div class="col-lg-8">

                <div class="row">

                    <div class="col-12">
                        
                        <div class="section-title">
                            <h4 class="m-0 text-uppercase font-weight-bold">Noticias Recientes</h4>
                        </div>

                    </div>

                    <div id="recentNews" class="row">

                        <% outstandingNotices.forEach((notice) => { %>

                            <div class="d-flex align-items-center bg-white mb-3" style="height: 110px;">

                                <img style="width: 40%; height: 60%;" class="img-fluid" 
                                    src="<%= notice.image_urls && notice.image_urls.length > 0 ? notice.image_urls[0] : '' %>" 
                                    alt="">

                                <div class="w-100 h-100 px-3 d-flex flex-column justify-content-center border border-left-0">

                                    <div class="mb-2">

                                        <a class="badge badge-primary text-uppercase font-weight-semi-bold p-1 mr-2">
                                            <%= getCategory(notice.category) %>
                                        </a>

                                        <a class="text-body"><small>
                                            <%= formatDateString(notice.publication_date) %>
                                        </small></a>

                                    </div>

                                    <a class="h6 m-0 text-secondary text-uppercase font-weight-bold"
                                        href="/notice/<%= encryptId(notice.idNotice.toString(), encryptionKey) %>">
                                        <%= notice.title %>
                                    </a>

                                </div>

                            </div>

                        <% }) %>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">

                <!-- Social Follow Start -->
                <div class="mb-3">
                    
                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold">Siguenos</h4>
                    </div>

                    <div class="bg-white border border-top-0 p-3">

                        <a href="" class="d-block w-100 text-white text-decoration-none mb-3"
                            style="background: #39569E;">

                            <i class="fab fa-facebook-f text-center py-4 mr-3"
                                style="width: 65px; background: rgba(0, 0, 0, .2);"></i>
                            
                            <span class="font-weight-medium">Ruined News</span>
                        </a>

                        <a href="" class="d-block w-100 text-white text-decoration-none mb-3"
                            style="background: #C8359D;">
                            
                            <i class="fab fa-instagram text-center py-4 mr-3"
                                style="width: 65px; background: rgba(0, 0, 0, .2);"></i>
                            
                            <span class="font-weight-medium">Ruined News</span>

                        </a>

                        <a href="" class="d-block w-100 text-white text-decoration-none mb-3"
                            style="background: #DC472E;">
                            
                            <i class="fab fa-youtube text-center py-4 mr-3"
                                style="width: 65px; background: rgba(0, 0, 0, .2);"></i>
                            
                            <span class="font-weight-medium">Ruined News Channel</span>

                        </a>

                        <a href="" class="d-block w-100 text-white text-decoration-none mb-3"
                            style="background: #111111;">

                            <i class="fab fa-tiktok text-center py-4 mr-3"
                                style="width: 65px; background: rgba(0, 0, 0, .2);"></i>

                            <span class="font-weight-medium">@RuinedNews</span>

                        </a>

                    </div>

                </div>
                <!-- Social Follow End -->

                <!-- Ads Start -->
                <div class="mb-3">
                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold">Publicidad</h4>
                    </div>
                </div>
                <!-- Ads End -->

                <!-- Popular News Start -->
                <div class="mb-3">

                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold">Gamming News</h4>
                    </div>

                    <div id="gammingPanel" class="bg-white border border-top-0 p-3">

                        <% outstandingNotices.forEach((notice) => { %>

                            <div class="col-lg-6">

                                <div class="position-relative mb-3">

                                    <img class="img-fluid w-100" src="<%= notice.image_urls && notice.image_urls.length > 0 ? notice.image_urls[0] : '' %>" 
                                    style="object-fit: cover;">
                            
                                    <div class="bg-white border border-top-0 p-4">

                                        <div class="mb-2">

                                            <a class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2" href="">
                                                <%= getCategory(notice.category) %>
                                            </a>

                                            <a class="text-body" href=""><small>
                                                <%= formatDateString(notice.publication_date) %>
                                            </small></a>

                                        </div>

                                        <a class="h4 d-block mb-3 text-secondary text-uppercase font-weight-bold"
                                            href="/notice/<%= encryptId(notice.idNotice.toString(), encryptionKey) %>">
                                            <%= notice.title %>
                                        </a>

                                        <p class="m-0">
                                            <%= notice.description.length > 150 ? notice.description.substring(0, 150) + "..." : notice.description %>
                                        </p>

                                    </div>
                                    
                                </div>

                            </div>

                        <% }) %>

                    </div>

                </div>
                <!-- Popular News End -->


                <!-- Tags Start -->
                <div class="mb-3">

                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold">Tags</h4>
                    </div>

                    <div class="bg-white border border-top-0 p-3">

                        <div class="d-flex flex-wrap m-n1">

                            <a href="" class="btn btn-sm btn-outline-secondary m-1">Gaming</a>
                            <a href="" class="btn btn-sm btn-outline-secondary m-1">Business</a>
                            <a href="" class="btn btn-sm btn-outline-secondary m-1">Nature</a>
                            <a href="" class="btn btn-sm btn-outline-secondary m-1">Education</a>
                            <a href="" class="btn btn-sm btn-outline-secondary m-1">Science</a>
                            <a href="" class="btn btn-sm btn-outline-secondary m-1">Foods</a>
                            <a href="" class="btn btn-sm btn-outline-secondary m-1">Travel</a>
                            
                        </div>

                    </div>

                </div>
                <!-- Tags End -->

            </div>

        </div>

    </div>

</div>