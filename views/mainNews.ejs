<div class="container-fluid">

    <div class="row">

        <div class="col-lg-7 px-0">

            <div class="swiper main-swiper">

                <div class="swiper-wrapper">

                    <% mainNotices.forEach((notice) => { %>

                        <div class="swiper-slide">

                            <!-- Data carousel main-->
                            <div class="position-relative overflow-hidden" style="height: 500px;">

                                <img class="img-fluid h-100" 
                                src="/notice/<%= notice.image_urls && notice.image_urls.length > 0 ? notice.image_urls[0] : '' %>" 
                                style="object-fit: cover;">

                                <div class="overlay">

                                    <div class="mb-2">

                                        <a class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2"
                                            href="">
                                            <%= getCategory(notice.category) %>
                                        </a>

                                        <a class="text-white" href="">
                                            <%= formatDateString(notice.publication_date) %>
                                        </a>

                                    </div>

                                    <a id="<%= encryptId(notice.idNotice.toString(), encryptionKey) %>" class="h2 m-0 text-white text-uppercase font-weight-bold btnShowNotice">
                                        <%= notice.title %>
                                    </a>

                                </div>

                            </div>

                        </div>

                    <% }) %>

                </div>

                <!-- navigation buttons (optional) -->
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>

                <!-- pagination (optional) -->
                <div class="swiper-pagination"></div>

            </div>

        </div>

        <div class="col-lg-5 px-0">

            <div id="first4News" class="row mx-0">

                <% outstandingNotices.forEach((notice) => { %>

                    <!-- primeras 4 noticias-->
                    <div class="col-md-6 px-0">

                        <div class="position-relative overflow-hidden" style="height: 250px;">

                            <img class="img-fluid w-100 h-100" src="<%= notice.image_urls && notice.image_urls.length > 0 ? notice.image_urls[0] : '' %>" style="object-fit: cover;">

                            <div class="overlay">

                                <div class="mb-2">

                                    <a class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2"
                                        href=""><%= getCategory(notice.category) %>
                                    </a>

                                    <a class="text-white" href="">
                                        <small><%= formatDateString(notice.publication_date) %></small>
                                    </a>

                                </div>

                                <a id="<%= encryptId(notice.idNotice.toString(), encryptionKey) %>" class="h6 m-0 text-white text-uppercase font-weight-semi-bold btnShowNotice">
                                    <%= notice.title %>
                                </a>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        </div>

    </div>
    
</div>